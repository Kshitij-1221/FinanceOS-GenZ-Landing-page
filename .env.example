# ── Formspree endpoint for the FinalCTA email-capture form ─────────
# 1. Sign in to https://formspree.io and create a new form.
# 2. Copy the form URL (looks like https://formspree.io/f/xxxxxxx).
# 3. Copy this file to .env.local and paste the URL below.
# 4. The FinalCTA component reads NEXT_PUBLIC_FORMSPREE_ENDPOINT at build/run time.
#
# Until this is set, the form will short-circuit to a "preview" success state
# locally (no network call), so the rest of the page still works.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id
